# 이 파일은 Render 환경변수(Environment Variables) 등록용 참고 템플릿입니다.
# 실제로 .env 파일을 만들 필요 없음 — Render 대시보드의 Environment 탭에 직접 입력.

# ── Required ────────────────────────────────────────────────────────────────

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (사용자 DB)
# Project Settings → API → Project URL · service_role key
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJh...

# 세션 서명용 시크릿 (32자 이상 랜덤 문자열)
SESSION_SECRET=replace-with-32-plus-random-bytes

# Production 모드 (쿠키 secure 옵션 활성화)
NODE_ENV=production

# ── Optional ────────────────────────────────────────────────────────────────

# 출력 토큰 상한 (기본: 32000)
# MAX_TOKENS=32000

# 일반 작업 1건 timeout (기본: 900000ms = 15분)
# JOB_TIMEOUT_MS=900000
# 프린트 PDF 복원 timeout과 기본 모델(관리자 베타)
# JOB_TIMEOUT_PRINT_PDF_RESTORE_MS=5400000
# PRINT_RESTORE_MODEL=claude-opus-4-8

# 완료 산출물 RAM 캐시 상한/TTL. 운영에서는 Supabase 파일함(24시간)이 원본이며,
# 메모리 캐시는 빠른 직후 다운로드용으로만 유지한다.
# JOB_ARTIFACT_MEMORY_MAX_BYTES=134217728
# JOB_ARTIFACT_MEMORY_TTL_MS=900000
# Supabase 파일함 저장 일시 오류 재시도(최대 4회). 실패하면 완료·정산하지 않음.
# REPORT_STORAGE_RETRY_ATTEMPTS=3
# REPORT_STORAGE_RETRY_BASE_DELAY_MS=250
# 서버 전체 동시 생성 상한(초과 요청은 abort 가능한 FIFO 대기열 사용)
# MAX_CONCURRENT_GENERATIONS=10
# 생성 대기열 최대 길이/최대 대기시간. 포화 시 업로드 전에 503으로 거부한다.
# MAX_GENERATION_QUEUE=6
# GENERATION_QUEUE_TIMEOUT_MS=600000
# multipart 입력 Buffer의 서버 전체 RAM 예산(요청별 상한 이상이어야 함)
# MAX_UPLOAD_MEMORY_MB=256
# VIBE_IMAGE_CONCURRENCY_PER_USER=2
# VERIFY_EXEMPT_EMAILS=test-account@your-school.example
# ALLOW_STATELESS_PRODUCTION=0

# ChatGPT/MCP OAuth 동적 클라이언트 등록 제한(신뢰 프록시 기준 IP당 시간당)
# MCP_OAUTH_REGISTRATION_LIMIT=30
# ChatGPT 이외 callback을 열 때는 완전한 HTTPS URL을 쉼표로 구분한다.
# 부분 문자열/prefix가 아니라 정확히 일치하는 URL만 허용된다.
# MCP_OAUTH_REDIRECT_ALLOWLIST=https://client.example/oauth/callback

# ── 서비스 품질 관측·선택형 이용 분석 ──────────────────────────────────────
# 0이면 운영/제품 텔레메트리 기록과 자동 정리를 모두 비활성화한다.
# 기본값은 1이며, db/migrations/20260715_add_product_telemetry.sql 적용 필요.
# PRODUCT_TELEMETRY_ENABLED=1
# 개인정보처리방침의 선택 동의 버전. 변경하면 사용자는 다시 선택해야 한다.
# PRODUCT_ANALYTICS_CONSENT_VERSION=2026-07-15

# ── PDF 통번역 (선택) ────────────────────────────────────────────────────────
# 이미지 OCR 및 PDF strict OCR 공급자. 이미지 OCR 기능을 열려면 필수.
# MISTRAL_API_KEY=...
# MISTRAL_OCR_MODEL=mistral-ocr-4-0
# 이미지 OCR은 6000px까지 보존하고, 평균 신뢰도가 0.90 미만이면 보정본을 재판독한다.
# IMAGE_OCR_MAX_EDGE=6000
# IMAGE_OCR_MAX_PIXELS=80000000
# IMAGE_OCR_RETRY_CONFIDENCE=0.90
# 일반 사용자의 전체 PDF 페이지 상한. 스캔본도 같은 상한을 사용한다.
# 관리자는 페이지 수 검사만 면제되고 이미지/메모리/요청 크기 안전장치는 유지된다.
# PDF_TRANSLATE_MAX_PAGES=700
# LibreOffice reflow is operator-gated and remains off unless both this flag
# and a usable LibreOffice binary are present.
# PDF_TRANSLATE_LIBREOFFICE_ENABLED=0
# 과거 PDF_OCR_MAX_PAGES는 폐기되어 값이 남아 있어도 무시된다.
# PDF_OCR_PROVIDER_BATCH_PAGES=50
# PDF_OCR_PROVIDER_CONCURRENCY=2
# PDF_OCR_RISK_VISUAL_BATCH_PAGES=4
# PDF_OCR_RISK_VISUAL_BATCH_TILES=12
# PDF_OCR_RISK_VISUAL_BATCH_BYTES=8388608
# PDF_OCR_RISK_VISUAL_BATCH_TOKENS=20
# MISTRAL_OCR_INLINE_MAX_MB=45
# MISTRAL_OCR_MAX_FILE_MB=512
# MISTRAL_OCR_CLEANUP_TIMEOUT_MS=20000
# PDF_TRANSLATE_TIMEOUT_MS=5400000

# 건의사항/버그 제보 이메일 알림 (Resend 사용)
# RESEND_API_KEY=re_...
# FEEDBACK_EMAIL_FROM="보고서 작성 툴 <noreply@example.com>"
# FEEDBACK_EMAIL_TO=admin@example.com

# ── Quilo Bot (선택) ──────────────────────────────────────────────────────────
# 기본은 빠르고 저렴한 OpenAI gpt-4o-mini. OPENAI_API_KEY가 있으면 자동 선택된다.
# OPENAI_API_KEY=sk-proj-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHAT_MEMO_MODEL=gpt-4o-mini
# OPENAI_CHAT_API_BASE=https://api.openai.com/v1
# 기존 Groq를 fallback으로 쓸 때만 CHAT_API_KEY=gsk_... 를 설정할 수 있다.
# CHAT_MEMO_MODEL=openai/gpt-oss-120b            # '메모 작성 도우미'용 (더 무거운 모델)
# CHAT_MAX_TOKENS=700                            # 답변 길이 상한
# CHAT_DAILY_MAX=1500                            # 전역 하루 메시지 상한(남용/비용 방지)
