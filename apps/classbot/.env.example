# Local server
PORT=4310
NODE_ENV=development
# 개발용 Vite origin. 운영에서 같은 origin으로 제공하면 비워 둔다.
CLASSBOT_ALLOWED_ORIGIN=http://localhost:5173
CLASSBOT_SESSION_SECRET=replace-with-at-least-32-random-characters
CLASSBOT_ADMIN_PASSWORD=replace-with-a-long-admin-password
CLASSBOT_CRON_SECRET=replace-with-a-long-random-cron-secret
# Optional shared secret checked on /api/kakao/skill via query `?secret=` or header.
CLASSBOT_KAKAO_SKILL_SECRET=replace-with-at-least-32-random-characters

# memory (local demo) or supabase (production)
CLASSBOT_STORAGE=memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Kakao Event API. Keep disabled until the business channel is ready.
KAKAO_EVENT_ENABLED=false
KAKAO_BOT_ID=
KAKAO_REST_API_KEY=
KAKAO_EVENT_NAME=quilo_schedule_notification
KAKAO_EVENT_API_BASE=https://bot-api.kakao.com

# The class defaults used when the database is initialized.
CLASSBOT_CLASS_CODE=2-4
CLASSBOT_CLASS_NAME=2학년 4반
CLASSBOT_TIMEZONE=Asia/Seoul

# Google Drive 자료실. 표시 이름이 아닌 Quilo 사용자 UUID를 명시한다.
# 폴더는 해당 Quilo OAuth 연결로 `Quilo schedule 자료실`을 자동 생성한다.
CLASSBOT_GOOGLE_DRIVE_OWNER_USER_ID=
CLASSBOT_GOOGLE_DRIVE_FOLDER_NAME=Quilo schedule 자료실
# drive.file scope로 같은 Quilo 앱이 만든 폴더만 override할 수 있다.
# CLASSBOT_GOOGLE_DRIVE_FOLDER_ID=
