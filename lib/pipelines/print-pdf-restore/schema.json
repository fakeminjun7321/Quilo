{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quilo print PDF semantic restoration page",
  "type": "object",
  "required": ["page"],
  "additionalProperties": false,
  "properties": {
    "page": {
      "type": "object",
      "required": ["source_index", "blocks", "confidence", "unreadable"],
      "properties": {
        "source_index": { "type": "integer", "minimum": 1, "maximum": 40 },
        "background": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "unreadable": { "type": "array", "items": { "type": "string" } },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 180,
          "items": {
            "type": "object",
            "required": ["type", "x", "y", "w", "h"],
            "properties": {
              "type": { "enum": ["text", "equation", "table", "diagram", "raster", "rule"] },
              "x": { "type": "number", "minimum": 0, "maximum": 1 },
              "y": { "type": "number", "minimum": 0, "maximum": 1 },
              "w": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
              "h": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
            }
          }
        }
      }
    }
  }
}
