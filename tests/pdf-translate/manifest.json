      "language_hint": "en",
      "render": true,
      "expected": {
        "valid_pdf": true,
        "encrypted": false,
        "page_count": 1,
        "page_boxes": [
          { "width_pt": 595.28, "height_pt": 841.89, "rotation": 0 }
        ],
        "text_tokens": [
          "FIXTURE-TEXT-001",
          "12.50 g",
          "298.15 K",
          "3.00 m/s",
          "0.250 mol/L",
          "6.022e23 mol^-1",
          "+/- 0.03 g",
          "A-17",
          "https://example.com/quilo/pdf-fixture?case=text-001",
          "https://doi.org/10.0000/quilo.fixture.001"
        ],
        "external_links": [
          "https://example.com/quilo/pdf-fixture?case=text-001",
          "https://doi.org/10.0000/quilo.fixture.001"
        ],
        "min_internal_links": 1,
        "min_outline_items": 1,
        "min_images": 0,
        "routing": {
          "mode": "inplace",
          "analysis": {
            "scanned": false,
            "garbled": false,
            "ocr_layer": false,
            "two_column": false
          },
          "math_density": { "max": 11.99 }
        }
      }
    },
