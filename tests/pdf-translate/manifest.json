{
  "schema_version": 1,
  "content_license": "CC0-1.0",
  "font_license_note": "Embedded repository fonts retain their upstream open-font licenses documented in THIRD_PARTY_NOTICES.md and lib/fonts/Pretendard-LICENSE.txt.",
  "description": "Deterministic synthetic regression corpus for the Quilo PDF translation pipeline.",
  "generation": {
    "script": "tests/pdf-translate/generate_fixtures.py",
    "default_output": "tmp/pdfs/fixtures",
    "binary_files_committed": false
  },
  "routing_policy": {
    "math_density_threshold": 12.0,
    "inplace": "extractable text and math density below the threshold",
    "retypeset": "scan, hidden OCR layer, garbled text, or math density at/above the threshold",
    "reject": "not a PDF, malformed PDF, or password required"
  },
  "fixtures": [
    {
